# JWT
JWT_SECRET=your_jwt_secret_key

# Cloudflare R2
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_ACCOUNT_ID=your_account_id
R2_END_POINT=your_endpoint
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_BASE_URL=your_public_url

# Redis (External or Cloud)
REDIS_HOST=your_redis_host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# SMTP Gmail
SMTP_HOST=smtp.gmail.com
SMTP_MAIL_USERNAME=your_email@gmail.com
SMTP_MAIL_PASSWORD=your_app_password

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_SCOPE=email,profile
GOOGLE_REDIRECT_URI=http://localhost:8080/login/oauth2/code/google
GOOGLE_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_USERINFO_URL=https://www.googleapis.com/oauth2/v3/userinfo

# VNPAY
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURN_URL=http://localhost:8080/api/v1/payment/vnpay-return
VNP_TMN_CODE=your_tmn_code
VNP_HASH_SECRET_KEY=your_hash_secret
VNP_API_URL=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction
